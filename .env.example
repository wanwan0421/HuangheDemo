# ===================================
# 黄河数字孪生平台环境变量示例
# Yellow River Digital Twin Platform
# ===================================

# ============ 后端 API 配置 ============
# 本地开发环境: http://localhost:3000
# 生产环境示例: https://api.your-domain.com
VITE_BACK_URL=http://localhost:3000
VITE_REMOTE_SENSING_URL=http://127.0.0.1:8002/api/remote-sensing

# ============ Mapbox 配置 ============
# 前往 https://www.mapbox.com/ 获取你自己的 Access Token
# 请将下面的示例 token 替换为你自己的正式 token
VITE_MAPBOX_TOKEN=pk.your_mapbox_token_here

# ============ 开发服务器端口 ============
# Vite 默认开发端口通常为 5173
# VITE_PORT=5173

# ============ 调试开关 ============
# 是否开启调试模式
# VITE_DEBUG=true

# 是否开启性能分析
# VITE_ENABLE_PROFILING=false

# ============ 可选监控与分析配置 ============
# 如需接入埋点、错误监控等，可在这里补充对应配置
# VITE_ANALYTICS_ID=your_analytics_id
# VITE_SENTRY_DSN=your_sentry_dsn

# ===================================
# 使用说明
# ===================================
# 1. 将本文件复制为 .env
# 2. 按需修改其中的配置项
# 3. 不要将包含真实密钥的 .env 提交到代码仓库
# 4. 生产环境建议使用专门的 .env.production 文件
