# ===================================
# 黄河数字孪生平台环境变量配置
# Yellow River Digital Twin Platform
# ===================================

# ============ 后端 API 配置 ============
# 开发环境: http://localhost:3000
# 生产环境: https://api.your-domain.com
VITE_BACK_URL=http://localhost:3000

# ============ Mapbox 配置 ============
# 从 https://www.mapbox.com/ 获取你的 Access Token
# 注册并创建一个新的 token 用于开发/生产环境
VITE_MAPBOX_TOKEN=pk.your_mapbox_token_here

# ============ 开发配置 ============
# Vite 开发服务器端口（可选，默认 5173）
# VITE_PORT=5173

# ============ 功能开关 ============
# 是否启用调试模式
# VITE_DEBUG=true

# 是否启用性能分析
# VITE_ENABLE_PROFILING=false

# ============ 第三方服务配置 ============
# 如果需要其他第三方服务，在此添加
# VITE_ANALYTICS_ID=your_analytics_id
# VITE_SENTRY_DSN=your_sentry_dsn

# ===================================
# 使用说明
# ===================================
# 1. 复制此文件为 .env
# 2. 填写实际的配置值
# 3. 不要将 .env 文件提交到版本控制系统
# 4. 生产环境请使用 .env.production 文件
